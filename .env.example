# =============================================================================
# Pointer TON — environment variables
# Copy to `.env.local` and fill in. Never commit `.env.local`.
# =============================================================================

# ----------------------------- runtime ----------------------------------------
# Optional for Windows TLS issues: `npm run dev` uses `node --use-system-ca` so outbound HTTPS matches the OS trust store.
# `npm run build` / `npm run start` use plain `next` (worker-safe).
#
# Must match `npm run dev` (default port 3001 for pointer-ton).
# Used as the canonical origin for invite links: ${NEXT_PUBLIC_APP_URL}/@YOURCODE (see proxy.ts).
NEXT_PUBLIC_APP_URL="http://127.0.0.1:3001"
NODE_ENV="development"

# ----------------------------- TonConnect / session ---------------------------
# Server-only: HS256 secret for Pointer session JWT after TonConnect proof (min ~32 random chars).
POINTER_SESSION_SECRET=""

# UI polish: when 1 or true, empty token Activity / Top traders / Holders show synthetic rows.
# Without rebuild: localStorage.setItem('pointer-ui-demo','1'); location.reload() (token page shows a dev banner).
NEXT_PUBLIC_UI_DEMO_MODE=""
# Founder beta: desktop-only gate + 0.001 SOL min buy presets for manual Phantom E2E on localhost.
NEXT_PUBLIC_FOUNDER_BETA=""
# Pulse row QA tags (protocol / quote / ingest source). Also: localStorage `pointer-pulse-tech-labels=1`
NEXT_PUBLIC_POINTER_PULSE_TECH_LABELS=""

# Diagnostics / bug payloads (optional UI label shown in-report; defaults package version).
NEXT_PUBLIC_POINTER_VERSION=""
# Landing page hero loop — set to a path under /public (e.g. /landing/hero-loop.mp4)
# or a fully-qualified CDN URL. Leave blank to render the static placeholder frame.
NEXT_PUBLIC_LANDING_HERO_VIDEO_URL=""
# Optional tilted flank loops beside the hero headline (Axiom-style). Can be different clips.
NEXT_PUBLIC_LANDING_HERO_VIDEO_LEFT_URL=""
NEXT_PUBLIC_LANDING_HERO_VIDEO_RIGHT_URL=""
# Discord/Slack incoming webhook — required for beta bug reports to reach you.
BUG_REPORT_WEBHOOK_URL=""

# ----------------------------- Coin Communities -------------------------------
# Per-token community feed (replaces dead X Communities). Create a key in the
# coincommunities.org business dashboard. Sent as x-api-key, server-side only.
COIN_COMMUNITIES_API_KEY=""
COIN_COMMUNITIES_API_BASE="https://api.coin-communities.xyz"
# Show bottom-bar issue counter pill (dev/debug only).
NEXT_PUBLIC_POINTER_DEBUG_CHROME=""
# Skip Upstash public API rate limit locally when quota is exhausted.
POINTER_DISABLE_PUBLIC_RATE_LIMIT=""

# ----------------------------- Privy (primary account) --------------------------------
# https://dashboard.privy.io — same pattern as the `pointer` repo.
NEXT_PUBLIC_PRIVY_APP_ID=""
# Server-only: Privy app secret (never expose to the browser).
PRIVY_APP_SECRET=""
# Privy server signer (emergency protective sells on embedded wallets).
# 1) openssl ecparam -name prime256v1 -genkey -noout -out private.pem && openssl ec -in private.pem -pubout -out public.pem
# 2) Register public.pem quorum in Privy Dashboard → Authorization keys
# 3) Enable Server-side access + signers on embedded wallets
PRIVY_AUTHORIZATION_PRIVATE_KEY=""
PRIVY_SIGNER_KEY_QUORUM_ID=""
NEXT_PUBLIC_PRIVY_SIGNER_KEY_QUORUM_ID=""

# ----------------------------- Admin control room -----------------------------
# Comma-separated founder emails (Gmail/email Privy logins) — auto-superadmin on first /admin visit.
ADMIN_BOOTSTRAP_EMAILS=""
# Comma-separated founder wallet addresses (optional, for wallet-first logins).
ADMIN_BOOTSTRAP_WALLETS=""
# Break-glass header secret (optional). x-pointer-admin-secret — unset in prod when not needed.
POINTER_ADMIN_SECRET=""

# ----------------------------- Supabase ---------------------------------------
# https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=""
# Optional: internal PostgREST URL (e.g. direct API) if different from NEXT_PUBLIC; defaults to NEXT_PUBLIC URL.
SUPABASE_SERVICE_URL=""
# Client-side: publishable key (sb_publishable_...) or legacy anon JWT.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-side: secret key (sb_secret_...) or legacy service_role JWT.
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_PROJECT_ID=""
# For Prisma/Drizzle/raw SQL from serverless, use Supabase transaction pooler (port 6543), not the REST URL.
# DATABASE_URL="postgres://postgres.<ref>:<password>@aws-0-...pooler.supabase.com:6543/postgres?pgbouncer=true"

# ----------------------------- Helius -----------------------------------------
# https://dashboard.helius.dev — canonical Solana RPC key (Developer plan).
# All Solana JSON-RPC goes through https://mainnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}.
HELIUS_API_KEY=""
# Browser / Privy embedded-wallet sign+send (same Helius key or full URL — exposed to client).
# Prefer NEXT_PUBLIC_HELIUS_API_KEY mirroring HELIUS_API_KEY for local dev.
NEXT_PUBLIC_HELIUS_API_KEY=""
# Optional full-URL override instead of the key above (e.g. Helius or custom RPC).
NEXT_PUBLIC_SOLANA_RPC_URL=""
# Optional WSS override when NEXT_PUBLIC_SOLANA_RPC_URL is set (defaults http→wss swap).
NEXT_PUBLIC_SOLANA_RPC_WS_URL=""
# QA desk wiring — enrich/hydrate only this mint (saves Supabase + RPC quota)
# POINTER_QA_MINT=CExejcGZSEnk4FBsBQa3nMnU1jjCYsjw4x9d7cJ4pump
# POINTER_QA_MINT_ONLY=1
# NEXT_PUBLIC_POINTER_QA_MINT=CExejcGZSEnk4FBsBQa3nMnU1jjCYsjw4x9d7cJ4pump
# QA chain indexer — webhook + replay ingest (set pool after backfill resolves DexScreener pair)
# POINTER_QA_INDEXER=1
# POINTER_QA_INDEXER_POOL=8YAyrz42UK6dtDUHga58esyBzSpjqLYovj9RkLusnMA1
# Optional: Moralis top-holders (not in repo .env.example before — add if you have a key)
# MORALIS_API_KEY=""
# Optional full-URL override when HELIUS_API_KEY is unset (dev fallback only).
SOLANA_RPC_URL=""
HELIUS_SENDER_URL="https://sender.helius-rpc.com/fast"
# Set in Helius webhook config as the Authorization header.
HELIUS_WEBHOOK_AUTH_TOKEN=""
# Returned by scripts/setup-helius-webhooks.ts — required for scripts/update-webhook-url.ts
HELIUS_WEBHOOK_ID=""

# Comma-separated `pad:pubkey` pairs that drive Pulse "New" via DAS
# `getAssetsByAuthority(...sortBy: created desc)`. When empty the built-in
# launchpad authorities (currently pump.fun) in `LAUNCHPAD_AUTHORITIES` are used.
# Recognized pads: pump.fun, bonk, bags, printr, moonshot, heaven, dynamic-bc.
# Example: PULSE_DAS_LAUNCHPAD_AUTHORITIES="pump.fun:TSLvdd1pWpHVjahSpsvCXUbgwsL3JAcvokwaKt1eokM,bonk:7eHQzMaFT5jt8cVaPQ5jvGV2hLnaPyfod4B8gM3f4VZQ"
PULSE_DAS_LAUNCHPAD_AUTHORITIES=""

# LEGACY (dev-only fallback): Helius DAS `searchAssets` requires `ownerAddress`
# when using tokenType=fungible, and a fixed owner returns a fixed set of mints
# (so the New < 30m column drains after the first ingest). Used only when no
# launchpad authority resolves above. Prefer the authority path.
PULSE_DAS_POLL_OWNER_WALLET=""
# Set to 1 to log DAS poll requests, responses, and New-column DB filter context.
POINTER_DEBUG_DAS=""

# Optional: protect cron routes (Bearer or X-Cron-Secret). Required in production.
# Endpoints: /api/cron/discover-tokens, enrich-pulse, index-active-mints,
# retry-failed-indexes (legacy: pulse-poll).
CRON_SECRET=""
# Optional: protect POST /api/indexer/auto-backfill (X-Pointer-Internal header).
POINTER_CRON_SECRET=""

# SplitNOW — private wallet funding (server-only; never expose to client)
# https://splitnow.io/account/api-keys
SPLITNOW_API_KEY=""

# ----------------------------- Jito -------------------------------------------
JITO_TIP_LAMPORTS="100000"
# Optional: override default Block Engine.
JITO_BLOCK_ENGINE_URL="https://mainnet.block-engine.jito.wtf"

# ----------------------------- Pointer fee program (Anchor, devnet) -----------
# Deployed program id after `anchor deploy` (see anchor/README.md).
POINTER_FEE_PROGRAM_ID=""
# Optional: browser-visible PDA helpers / future client-built fee top-ups.
NEXT_PUBLIC_POINTER_FEE_PROGRAM_ID=""

# ----------------------------- Pointer platform fees (Jupiter) ----------------
# Cold wallet that receives the 1% platform fee (Pointer derives wrapped-SOL ATA per swap).
JUPITER_REFERRAL_ACCOUNT=""
# Optional: pre-initialized SPL token account to receive fees (skips ATA derivation).
# JUPITER_FEE_TOKEN_ACCOUNT=""
# Wallet that signs/admin's the referral account (kept server-side).
JUPITER_REFERRAL_ADMIN_WALLET=""

# Jupiter API key — free at https://portal.jup.ag (higher rate limits on api.jup.ag).
JUPITER_API_KEY=""
# Optional overrides (defaults: lite-api.jup.ag/swap/v1 for quote+swap, api.jup.ag/price/v3 for prices).
# JUPITER_QUOTE_URL="https://lite-api.jup.ag/swap/v1/quote"
# JUPITER_SWAP_URL="https://lite-api.jup.ag/swap/v1/swap"
JUPITER_PRICE_API_URL=""

# ----------------------------- Upstash Redis ----------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Per-IP sliding window for unauthenticated public API routes (e.g. prices, resolve). Default 120/min if unset.
PUBLIC_API_RATE_LIMIT_PER_MIN="120"

# ----------------------------- Sentry (optional) -------------------------------
# Client + server: use NEXT_PUBLIC_SENTRY_DSN so the browser can report; or SENTRY_DSN server-only (no client reports).
NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_DSN=""
SENTRY_ENVIRONMENT=""
# Source maps / release (CI): set all three to enable withSentryConfig upload in next build.
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# ----------------------------- AI providers -----------------------------------
ANTHROPIC_API_KEY=""
ANTHROPIC_HAIKU_MODEL="claude-haiku-4-5"
ANTHROPIC_SONNET_MODEL="claude-sonnet-4-6"

GOOGLE_GEMINI_API_KEY=""
GEMINI_FLASH_MODEL="gemini-2.5-flash"

OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# ----------------------------- Kalshi (Predictions desk) ----------------------
# Public market data needs no auth. Trading requires RSA key pair from Kalshi dashboard.
# API docs: https://docs.kalshi.com
KALSHI_API_BASE="https://api.elections.kalshi.com/trade-api/v2"
KALSHI_API_KEY_ID=""
# PEM private key — use literal newlines or \n escapes in .env.local
KALSHI_PRIVATE_KEY=""

# ----------------------------- Phase 2 ---------------------------------------
# Referrals: REFERRER's share of platform fee (basis points of referee fee). Default 3000 = 30%.
REFERRAL_FEE_SHARE_BPS=3000
# Optional: public display / client-side (fallback 30% in UI if unset on server bundle)
NEXT_PUBLIC_REFERRAL_FEE_SHARE_BPS=3000

# Cashback: the TRADER's own rebate on the platform fee they pay (basis points). Default 5000 = 50%.
# Distinct from (and stacks with) the referral share above. Accrued per trade to the cashback ledger.
CASHBACK_SHARE_BPS=5000
# Optional: public display / client-side (fallback 50% in UI if unset on server bundle)
NEXT_PUBLIC_CASHBACK_SHARE_BPS=5000

# ----------------------------- Packs (live commerce) -------------------------
# Real pack commerce is OFF until BOTH the PACKS_LIVE_COMMERCE_ENABLED flag
# (lib/packs/mode.ts) is true AND a treasury signer is set here. Until then packs
# run on the simulated ledger (no charge, no on-chain delivery).
#
# Treasury hot wallet that (1) receives pack-price SOL and (2) buys + delivers
# won tokens to users. base58 secret key OR a JSON array (Solana CLI keypair).
# SECURITY: server-only hot key — fund conservatively, never commit, never expose.
PACKS_TREASURY_SECRET_KEY=""
# Client-safe deposit address (the pack-price transfer target shown to users).
# Optional — derived from the secret key when omitted.
NEXT_PUBLIC_PACKS_TREASURY_ADDRESS=""

# Points formula label (displayed on /points)
POINTS_FORMULA_VERSION=v1

# Manual referral payout bookkeeping (protect POST /api/referrals/payout)
POINTER_ADMIN_SECRET=""

# ----------------------------- TON (Pulse + token charts) ----------------------
# TON Center JSON-RPC (account state checks for jetton masters). Optional API key
# for higher limits: https://toncenter.com/
TON_CENTER_API_URL="https://toncenter.com/api/v2/jsonRPC"
TON_CENTER_API_KEY=""
#
# TonAPI — jetton list/metadata (`/v2/jettons`), display rates (`/v2/rates`) for chart spot.
# Free tier works without key; use a key from https://tonconsole.com for production limits.
TON_API_BASE_URL="https://tonapi.io"
TON_API_KEY=""
# Set to 1 to log Pulse Ton poll / feed debug lines from `lib/helius/feed.ts`.
POINTER_DEBUG_TONAPI=""

# Optional STON.fi swap referral (DEX v2 — address + fee 0–100 bps; see STON docs).
STONFI_REFERRAL_ADDRESS=""
STONFI_REFERRAL_FEE_BPS="10"

# ----------------------------- Beta gate (pre-launch) -------------------------
# When true, proxy requires a valid ptr_beta cookie (set by POST /api/beta/redeem).
# Public: /, /beta, static assets, and all /api/* routes.
BETA_GATE_ENABLED="false"
# HMAC secret for beta session cookie (use a long random string).
BETA_SESSION_SECRET=""
# Pepper for hashing invite codes at rest (SHA-256).
BETA_CODE_PEPPER=""
# Comma-separated founder Solana wallet addresses (Base58) for POST /api/beta/generate.
BETA_FOUNDER_WALLETS=""

# ----------------------------- Twitter / X ------------------------------------
# SocialData.tools — richer Pulse Twitter hover profiles (https://socialdata.tools)
SOCIALDATA_API_KEY=""
# Official X API v2 bearer token (alternative to SocialData).
TWITTER_BEARER_TOKEN=""

# ----------------------------- Fiat on-ramp (Onramper) -----------------------
# Publishable widget key (`pk_*`) — may be exposed to the browser for static builds.
NEXT_PUBLIC_ONRAMPER_API_KEY=""
# Optional duplicate kept server-side for rotation/separation from client bundles.
ONRAMPER_API_KEY=""
# HMAC signing secret Onramper provides for pinning destination addresses (`networkWallets`, etc.).
ONRAMPER_SIGNING_SECRET=""
# Optional comma list to limit providers (`moonpay` example). Leaving blank enables widest regional fallback.
ONRAMPER_ONLY_ONRAMPS=""

# ----------------------------- Pointer Financial (Bridge) --------------------
# The single provider behind the capital layer: KYC'd customers, virtual bank
# accounts + rails, and issued cards (virtual/physical) with Apple Pay push
# provisioning. Users only ever see "Pointer Financial", never "Bridge".
# LEAVE BLANK to keep the whole layer in "not configured" mode: the app then uses
# its local activation/card simulation and no real accounts are created.
BRIDGE_API_KEY=""
# Defaults to the sandbox host when blank; set to the production host to go live.
BRIDGE_API_BASE=""
# Yield engine for idle USDC (Lulo, lulo.fi). Get a key at dev.lulo.fi. Blank =
# Smart Yield shows the demo APY. Read-only rates need only this key; deposits are
# signed client-side. Users only ever see "Smart Yield", never "Lulo".
LULO_API_KEY=""
LULO_API_BASE=""
# Crossmint webhook signing secret (whsec_…) from the Crossmint console → Webhooks
# → endpoint → Signing Secret. Verifies Apple Pay buy events (Svix) so completed
# purchases record as buys (cost-basis + points). Blank = webhook disabled.
CROSSMINT_WEBHOOK_SECRET=""
# Gas sponsorship — so users never need to hold SOL. Base58 64-byte secret key
# (Phantom "Export Private Key") of a Pointer-owned wallet funded with a little
# SOL. Before an on-chain action, the backend tops the user's wallet up with just
# enough SOL for the fee. KEEP ONLY GAS MONEY HERE; server env only, never commit.
# Blank = no sponsorship (users pay their own gas).
SOLANA_SPONSOR_SECRET=""

# ----------------------------- Creator portal (clipping program) -----------------
# Discord OAuth — https://discord.com/developers/applications
# Redirect URI: ${NEXT_PUBLIC_APP_URL}/api/creators/auth/discord/callback
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
# Comma-separated Discord user IDs allowed to use /portal/admin
CREATOR_ADMIN_DISCORD_IDS=""
# Optional; falls back to POINTER_SESSION_SECRET for creator portal JWT cookies
CREATOR_PORTAL_SESSION_SECRET=""
# Dev: auto-enabled in NODE_ENV=development — set to 1 to force in other envs
CREATOR_PORTAL_DEV_LOGIN=""
# Dev: return 75k views when scrape fails (also auto-mocks in dev login mode)
CREATOR_PORTAL_MOCK_VIEWS=""
