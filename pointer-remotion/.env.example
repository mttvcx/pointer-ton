# ElevenLabs text-to-speech — required for `npm run build-vo`.
# Get a key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_key_here

# Optional: override the narrator voice (deep, measured documentary male by default).
# Find IDs with the voices listing printed by build-vo.ts, or in the ElevenLabs voice library.
# ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9
