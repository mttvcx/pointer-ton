# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.tools/

# Cursor IDE
.cursor/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.local.*
.env.development.local
.env.test.local
.env.production.local
!.env.example

# local dev artifacts (never commit)
.dev-server.log
expo-*.log
metro.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Anchor / Solana program build
anchor/target/
anchor/**/*.so

.vercel

# NOTE: main ignores `apps/` (mobile is a "sibling project" there). This is the
# mobile branch, which OWNS apps/mobile — so it is NOT ignored here. Do not carry
# this line back to main (the mobile app stays out of main; merge backend files only).
