# Copy to .env. EXPO_PUBLIC_* are inlined into the app at build time.
# Point at prod (default) or a preview deployment of the existing Pointer API.
EXPO_PUBLIC_API_URL=https://pointer-ton.vercel.app

# SAME Privy App ID as the web app (unified identity + embedded wallet).
EXPO_PUBLIC_PRIVY_APP_ID=
# Create an "Expo app client" in the Privy dashboard for this app id; paste its id here.
EXPO_PUBLIC_PRIVY_CLIENT_ID=
